# Neon DB Database URL (Get yours from neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk Keys (Get yours from dashboard.clerk.com)
# Set publicMetadata.role = "admin" on admin users in the Clerk dashboard
CLERK_SECRET_KEY=sk_test_placeholder_key

# Upstash Redis (Get yours from console.upstash.com)
UPSTASH_REDIS_REST_URL=https://placeholder-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=placeholder_token
